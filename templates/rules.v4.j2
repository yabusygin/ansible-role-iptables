{% extends "tables.j2" %}
{% import "macro.j2" as macros -%}

{% block filter_rules %}
    {% if iptables_filter_input_before_rules or iptables_filter_input_rules %}

        {% for rule in iptables_filter_input_before_rules %}
{{ macros.rule("INPUT", rule.options) }}
        {% endfor %}
        {% for rule in iptables_filter_input_rules %}
{{ macros.rule("INPUT", rule.options) }}
        {% endfor %}
    {% endif %}
    {% if iptables_filter_forward_rules %}

        {% for rule in iptables_filter_forward_before_rules %}
{{ macros.rule("FORWARD", rule.options) }}
        {% endfor %}
        {% for rule in iptables_filter_forward_rules %}
{{ macros.rule("FORWARD", rule.options) }}
        {% endfor %}
    {% endif %}
    {% if iptables_filter_output_rules %}

        {% for rule in iptables_filter_output_before_rules %}
{{ macros.rule("OUTPUT", rule.options) }}
        {% endfor %}
        {% for rule in iptables_filter_output_rules %}
{{ macros.rule("OUTPUT", rule.options) }}
        {% endfor %}
    {% endif %}
    {% for chain in iptables_filter_user_chains %}
        {% if "rules" in chain %}

            {% for rule in chain.rules %}
{{ macros.rule(chain.chain, rule.options) }}
            {% endfor %}
        {% endif %}
    {% endfor %}
{% endblock filter_rules %}
